{%- comment -%}
  BreadcrumbList Schema for Collection Pages
  Add this to your collection template or theme.liquid
{%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ shop.url }}"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ collection.title | escape }}",
      "item": "{{ shop.url }}/collections/{{ collection.handle }}"
    }
  ]
}
</script>
