{%- comment -%}
  Enhanced Product Schema for AEO
  Fixes: brand type, adds priceValidUntil, shippingDetails, returnPolicy, material

  Replace the existing product schema in your theme with this version.

  NOTE: For aggregateRating/review schema, integrate with your reviews app
  (Judge.me, Loox, etc.) - they typically inject this automatically.
{%- endcomment -%}

{%- assign price_valid_until = 'now' | date: '%Y' | plus: 1 | append: '-12-31' -%}

<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  "description": {{ product.description | strip_html | truncate: 5000 | json }},
  "url": "{{ shop.url }}/products/{{ product.handle }}",
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  {%- if product.selected_or_first_available_variant.barcode != blank -%}
  "gtin": {{ product.selected_or_first_available_variant.barcode | json }},
  {%- endif -%}
  "image": [
    {%- for image in product.images limit: 5 -%}
    "https:{{ image | image_url: width: 1200 }}"{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ],
  "brand": {
    "@type": "Organization",
    "@id": "https://shopcherri.com/#organization",
    "name": "Cherri",
    "url": "https://shopcherri.com"
  },
  "manufacturer": {
    "@type": "Organization",
    "name": "Cherri"
  },
  "material": "Organic Supima Cotton, Lenzing Modal",
  "audience": {
    "@type": "PeopleAudience",
    "suggestedGender": "female"
  },
  "category": "Underwear > {{ product.type | default: 'Panties' }}",
  "offers": [
    {%- for variant in product.variants -%}
    {
      "@type": "Offer",
      "url": "{{ shop.url }}/products/{{ product.handle }}?variant={{ variant.id }}",
      "priceCurrency": "{{ cart.currency.iso_code }}",
      "price": {{ variant.price | money_without_currency | remove: ',' }},
      "priceValidUntil": "{{ price_valid_until }}",
      "sku": {{ variant.sku | json }},
      "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "seller": {
        "@type": "Organization",
        "name": "Cherri"
      },
      "shippingDetails": {
        "@type": "OfferShippingDetails",
        "shippingRate": {
          "@type": "MonetaryAmount",
          "value": "8.99",
          "currency": "USD"
        },
        "shippingDestination": {
          "@type": "DefinedRegion",
          "addressCountry": "US"
        },
        "deliveryTime": {
          "@type": "ShippingDeliveryTime",
          "handlingTime": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 3,
            "unitCode": "DAY"
          },
          "transitTime": {
            "@type": "QuantitativeValue",
            "minValue": 3,
            "maxValue": 7,
            "unitCode": "DAY"
          }
        }
      },
      "hasMerchantReturnPolicy": {
        "@type": "MerchantReturnPolicy",
        "applicableCountry": "US",
        "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
        "merchantReturnDays": 7,
        "returnMethod": "https://schema.org/ReturnByMail",
        "returnFees": "https://schema.org/FreeReturn"
      }
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
