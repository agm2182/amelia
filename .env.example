# Cherri SEO Research - Environment Configuration
# ================================================
# Copy to ~/.config/cherri/.env and fill in values
# Run `bin/check-integrations` to verify setup

# ──────────────────────────────────────────────────
# GOOGLE (GSC, GA4)
# ──────────────────────────────────────────────────
# 1. Create GCP project: console.cloud.google.com → New Project → "cherri-seo-research"
# 2. Enable APIs: APIs & Services → Library → enable:
#    - Google Search Console API
#    - Google Analytics Data API
# 3. Create service account: IAM → Service Accounts → Create
#    - Name: "claude-code-seo"
#    - Skip role assignment (permissions granted at service level)
# 4. Create key: Click service account → Keys → Add Key → JSON
#    - Save as ~/.config/cherri/cherri-seo-credentials.json
#    - chmod 600 ~/.config/cherri/cherri-seo-credentials.json
# 5. Grant access:
#    - GSC: search.google.com/search-console → Settings → Users → Add service
#           account email with "Restricted" permission
#    - GA4: analytics.google.com → Admin → Property Access → Add service
#           account email with "Viewer" role
GOOGLE_APPLICATION_CREDENTIALS=~/.config/cherri/cherri-seo-credentials.json
GOOGLE_PROJECT_ID=cherri-seo-research

# ──────────────────────────────────────────────────
# SHOPIFY
# ──────────────────────────────────────────────────
# Token expires every 24 hours. Run: bin/refresh-shopify-token
# Credentials stored in: ~/.config/cherri/shopify-credentials.json
SHOPIFY_STORE=shop-cherri.myshopify.com
SHOPIFY_ACCESS_TOKEN=shpat_xxxxx

# ──────────────────────────────────────────────────
# META ADS (Facebook/Instagram)
# ──────────────────────────────────────────────────
# 1. Create app: developers.facebook.com/apps → Business type
# 2. Add Marketing API product
# 3. Generate token: Tools → Graph API Explorer
#    Scopes: ads_management, ads_read, business_management,
#            instagram_manage_comments, pages_show_list, pages_read_engagement
# 4. Token expires ~60 days. Regenerate at developers.facebook.com/tools/explorer
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=act_2026819017404527

# ──────────────────────────────────────────────────
# TIKTOK ADS
# ──────────────────────────────────────────────────
# 1. Create app: business-api.tiktok.com/portal/apps
# 2. Select Marketing API with read permissions
# 3. After approval, generate token in App Management
# 4. To refresh: see CLAUDE.md "Token Refresh" section
TIKTOK_ACCESS_TOKEN=
TIKTOK_SECRET=
TIKTOK_ADVERTISER_IDS=6872850369307738114,6872851292415328257

# ──────────────────────────────────────────────────
# EXA (Web/Code Search)
# ──────────────────────────────────────────────────
# Get key: dashboard.exa.ai
EXA_API_KEY=
