#!/usr/bin/env python3
"""Download all assets from the live Shopify theme."""

import json
import os
import sys
import time
import urllib.request
import urllib.error
import base64
from pathlib import Path

STORE = "shop-cherri.myshopify.com"
API_VERSION = "2025-01"
CREDS_PATH = os.path.expanduser("~/.config/cherri/shopify-credentials.json")
OUTPUT_DIR = Path(__file__).resolve().parent.parent / "theme"

BINARY_EXTENSIONS = {
    ".png", ".jpg", ".jpeg", ".gif", ".ico", ".webp", ".avif",
    ".woff", ".woff2", ".ttf", ".eot", ".otf",
    ".mp4", ".webm", ".mov",
    ".pdf", ".zip",
}


def load_token():
    with open(CREDS_PATH) as f:
        return json.load(f)["access_token"]


def api_get(token, path):
    url = f"https://{STORE}/admin/api/{API_VERSION}/{path}"
    req = urllib.request.Request(url, headers={
        "X-Shopify-Access-Token": token,
    })
    with urllib.request.urlopen(req) as resp:
        return json.loads(resp.read())


def find_live_theme(token):
    data = api_get(token, "themes.json")
    for theme in data["themes"]:
        if theme["role"] == "main":
            return theme["id"], theme["name"]
    print("No live theme found", file=sys.stderr)
    sys.exit(1)


def list_assets(token, theme_id):
    data = api_get(token, f"themes/{theme_id}/assets.json")
    return [a["key"] for a in data["assets"]]


def download_asset(token, theme_id, key):
    encoded_key = urllib.request.quote(key, safe="")
    path = f"themes/{theme_id}/assets.json?asset[key]={encoded_key}"
    data = api_get(token, path)
    asset = data["asset"]
    return asset


def main():
    token = load_token()
    theme_id, theme_name = find_live_theme(token)
    print(f"Downloading theme: {theme_name} (ID: {theme_id})")

    assets = list_assets(token, theme_id)
    print(f"Found {len(assets)} assets")

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)

    downloaded = 0
    skipped = 0
    errors = 0

    for i, key in enumerate(assets):
        dest = OUTPUT_DIR / key
        dest.parent.mkdir(parents=True, exist_ok=True)

        ext = Path(key).suffix.lower()
        progress = f"[{i + 1}/{len(assets)}]"

        try:
            asset = download_asset(token, theme_id, key)

            if "value" in asset:
                dest.write_text(asset["value"], encoding="utf-8")
                downloaded += 1
                print(f"{progress} {key}")
            elif "attachment" in asset:
                raw = base64.b64decode(asset["attachment"])
                dest.write_bytes(raw)
                downloaded += 1
                print(f"{progress} {key} (binary)")
            else:
                print(f"{progress} {key} - SKIP (no content)")
                skipped += 1

        except urllib.error.HTTPError as e:
            if e.code == 429:
                retry_after = float(e.headers.get("Retry-After", "2"))
                print(f"{progress} {key} - rate limited, waiting {retry_after}s")
                time.sleep(retry_after)
                # Retry once
                try:
                    asset = download_asset(token, theme_id, key)
                    if "value" in asset:
                        dest.write_text(asset["value"], encoding="utf-8")
                    elif "attachment" in asset:
                        dest.write_bytes(base64.b64decode(asset["attachment"]))
                    downloaded += 1
                    print(f"{progress} {key} (retried)")
                except Exception as e2:
                    print(f"{progress} {key} - ERROR on retry: {e2}",
                          file=sys.stderr)
                    errors += 1
            else:
                print(f"{progress} {key} - ERROR: {e}", file=sys.stderr)
                errors += 1

        except Exception as e:
            print(f"{progress} {key} - ERROR: {e}", file=sys.stderr)
            errors += 1

        # Shopify REST rate limit: 2 requests/second for assets
        time.sleep(0.5)

    print(f"\nDone! Downloaded: {downloaded}, Skipped: {skipped}, "
          f"Errors: {errors}")
    print(f"Theme saved to: {OUTPUT_DIR}")


if __name__ == "__main__":
    main()
