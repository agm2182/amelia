#!/usr/bin/env bash
#
# Verify all Cherri SEO integrations are working
# Usage: bin/check-integrations
#
# Dependencies: bash, curl, openssl, base64

set -uo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

PASSED=0
FAILED=0
SKIPPED=0

# Config directory
CONFIG_DIR="$HOME/.config/cherri"

# Load environment variables if present
if [[ -f "$CONFIG_DIR/.env" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_DIR/.env"
fi

pass() {
    echo -e "${GREEN}✓${NC} $1"
    [[ -n "${2:-}" ]] && echo "  $2"
    ((PASSED++))
}

fail() {
    echo -e "${RED}✗${NC} $1"
    [[ -n "${2:-}" ]] && echo "  $2"
    ((FAILED++))
}

skip() {
    echo -e "${YELLOW}○${NC} $1 (skipped)"
    [[ -n "${2:-}" ]] && echo "  $2"
    ((SKIPPED++))
}

# Base64url encode (RFC 4648)
base64url_encode() {
    openssl base64 -e -A | tr '+/' '-_' | tr -d '='
}

# Extract JSON field value (simple parser for well-formed JSON)
json_field() {
    local json="$1"
    local field="$2"
    # Handle multi-line values (like private_key with \n)
    echo "$json" | sed -n 's/.*"'"$field"'"[[:space:]]*:[[:space:]]*"\(.*\)".*/\1/p' | head -1
}

# Extract private key from JSON (handles escaped newlines)
extract_private_key() {
    local creds_file="$1"
    # Use awk to extract the private_key field and convert \n to actual newlines
    awk -F'"' '/"private_key"/ {for(i=1;i<=NF;i++) if($i=="private_key") print $(i+2)}' "$creds_file" | sed 's/\\n/\n/g'
}

# Extract client_email from JSON
extract_client_email() {
    local creds_file="$1"
    awk -F'"' '/"client_email"/ {for(i=1;i<=NF;i++) if($i=="client_email") print $(i+2)}' "$creds_file"
}

# Generate Google OAuth token from service account using openssl
get_google_token() {
    local scope="$1"
    local creds_file="$CONFIG_DIR/cherri-seo-credentials.json"

    if [[ ! -f "$creds_file" ]]; then
        echo ""
        return 1
    fi

    # Extract credentials
    local client_email
    client_email=$(extract_client_email "$creds_file")
    if [[ -z "$client_email" ]]; then
        echo ""
        return 1
    fi

    # Create JWT header
    local header='{"alg":"RS256","typ":"JWT"}'
    local header_b64
    header_b64=$(echo -n "$header" | base64url_encode)

    # Create JWT payload
    local now
    now=$(date +%s)
    local exp=$((now + 3600))
    local payload="{\"iss\":\"$client_email\",\"scope\":\"$scope\",\"aud\":\"https://oauth2.googleapis.com/token\",\"iat\":$now,\"exp\":$exp}"
    local payload_b64
    payload_b64=$(echo -n "$payload" | base64url_encode)

    # Create unsigned token
    local unsigned="$header_b64.$payload_b64"

    # Extract private key to temp file
    local keyfile
    keyfile=$(mktemp)
    extract_private_key "$creds_file" > "$keyfile"

    # Sign with openssl
    local signature
    signature=$(echo -n "$unsigned" | openssl dgst -sha256 -sign "$keyfile" 2>/dev/null | base64url_encode)
    rm -f "$keyfile"

    if [[ -z "$signature" ]]; then
        echo ""
        return 1
    fi

    # Create complete JWT
    local jwt="$unsigned.$signature"

    # Exchange JWT for access token
    local response
    response=$(curl -s -m 15 -X POST \
        -H "Content-Type: application/x-www-form-urlencoded" \
        -d "grant_type=urn:ietf:params:oauth:grant-type:jwt-bearer&assertion=$jwt" \
        "https://oauth2.googleapis.com/token" 2>&1)

    # Extract access token from response
    local token
    token=$(echo "$response" | grep -o '"access_token"[[:space:]]*:[[:space:]]*"[^"]*"' | cut -d'"' -f4)
    echo "$token"
}

echo "Checking Cherri SEO integrations..."
echo

# -----------------------------------------------------------------------------
# Google Search Console
# -----------------------------------------------------------------------------
echo "Google Search Console"
CREDS_FILE="$CONFIG_DIR/cherri-seo-credentials.json"
if [[ ! -f "$CREDS_FILE" ]]; then
    skip "API" "Missing $CREDS_FILE"
else
    GSC_TOKEN=$(get_google_token "https://www.googleapis.com/auth/webmasters.readonly" 2>/dev/null)
    if [[ -z "$GSC_TOKEN" ]]; then
        fail "Auth" "Failed to get access token"
    else
        response=$(curl -s -m 15 \
            -H "Authorization: Bearer $GSC_TOKEN" \
            "https://www.googleapis.com/webmasters/v3/sites" 2>&1 || echo "CURL_FAILED")

        if [[ "$response" == *'"siteEntry"'* ]] || [[ "$response" == *'"siteUrl"'* ]]; then
            site_count=$(echo "$response" | grep -o '"siteUrl"' | wc -l | tr -d ' ')
            pass "List sites" "$site_count site(s) accessible"
        elif [[ "$response" == *'CURL_FAILED'* ]]; then
            fail "List sites" "Connection failed"
        else
            fail "List sites" "$(echo "$response" | head -c 80)"
        fi
    fi
fi
echo

# -----------------------------------------------------------------------------
# Google Analytics 4
# -----------------------------------------------------------------------------
echo "Google Analytics 4"
GA4_PROPERTY_ID="386275004"
if [[ ! -f "$CREDS_FILE" ]]; then
    skip "API" "Missing $CREDS_FILE"
else
    GA4_TOKEN=$(get_google_token "https://www.googleapis.com/auth/analytics.readonly" 2>/dev/null)
    if [[ -z "$GA4_TOKEN" ]]; then
        fail "Auth" "Failed to get access token"
    else
        response=$(curl -s -m 15 \
            -H "Authorization: Bearer $GA4_TOKEN" \
            "https://analyticsdata.googleapis.com/v1beta/properties/${GA4_PROPERTY_ID}/metadata" 2>&1 || echo "CURL_FAILED")

        if [[ "$response" == *'"dimensions"'* ]]; then
            pass "Property access" "Property $GA4_PROPERTY_ID accessible"
        elif [[ "$response" == *'PERMISSION_DENIED'* ]]; then
            fail "Property access" "Permission denied - add service account to GA4 property"
        elif [[ "$response" == *'CURL_FAILED'* ]]; then
            fail "Property access" "Connection failed"
        else
            fail "Property access" "$(echo "$response" | head -c 80)"
        fi
    fi
fi
echo

# -----------------------------------------------------------------------------
# Meta Ads (Instagram/Facebook)
# -----------------------------------------------------------------------------
echo "Meta Ads (Instagram/Facebook)"
if [[ -z "${META_ACCESS_TOKEN:-}" ]]; then
    skip "API" "Missing META_ACCESS_TOKEN in $CONFIG_DIR/.env"
elif [[ -z "${META_AD_ACCOUNT_ID:-}" ]]; then
    skip "API" "Missing META_AD_ACCOUNT_ID in $CONFIG_DIR/.env"
else
    response=$(curl -s -m 15 \
        "https://graph.facebook.com/v21.0/${META_AD_ACCOUNT_ID}?fields=name,account_status&access_token=${META_ACCESS_TOKEN}" 2>&1 || echo "CURL_FAILED")

    if [[ "$response" == *'"name"'* ]]; then
        account_name=$(echo "$response" | grep -o '"name":"[^"]*"' | cut -d'"' -f4)
        pass "Ad account" "Account: $account_name"
    elif [[ "$response" == *'OAuthException'* ]] || [[ "$response" == *'access token'* ]]; then
        fail "Ad account" "Token expired - generate new token at developers.facebook.com"
    elif [[ "$response" == *'does not exist'* ]]; then
        fail "Ad account" "Invalid account ID or missing permissions"
    elif [[ "$response" == *'CURL_FAILED'* ]]; then
        fail "Ad account" "Connection failed"
    else
        fail "Ad account" "$(echo "$response" | head -c 80)"
    fi
fi
echo

# -----------------------------------------------------------------------------
# TikTok Ads
# -----------------------------------------------------------------------------
echo "TikTok Ads"
# Support both TIKTOK_ADVERTISER_ID (singular) and TIKTOK_ADVERTISER_IDS (plural, comma-separated)
TIKTOK_ADV_ID="${TIKTOK_ADVERTISER_ID:-}"
if [[ -z "$TIKTOK_ADV_ID" ]] && [[ -n "${TIKTOK_ADVERTISER_IDS:-}" ]]; then
    # Use first ID from comma-separated list
    TIKTOK_ADV_ID="${TIKTOK_ADVERTISER_IDS%%,*}"
fi

if [[ -z "${TIKTOK_ACCESS_TOKEN:-}" ]]; then
    skip "API" "Missing TIKTOK_ACCESS_TOKEN in $CONFIG_DIR/.env"
elif [[ -z "$TIKTOK_ADV_ID" ]]; then
    skip "API" "Missing TIKTOK_ADVERTISER_ID or TIKTOK_ADVERTISER_IDS in $CONFIG_DIR/.env"
else
    response=$(curl -s -g -m 15 \
        -H "Access-Token: ${TIKTOK_ACCESS_TOKEN}" \
        "https://business-api.tiktok.com/open_api/v1.3/advertiser/info/?advertiser_ids=[\"${TIKTOK_ADV_ID}\"]" 2>&1 || echo "CURL_FAILED")

    if [[ "$response" == *'"code":0'* ]] || [[ "$response" == *'"code": 0'* ]]; then
        # Handle JSON with or without spaces after colons
        adv_name=$(echo "$response" | grep -oE '"name":[[:space:]]*"[^"]*"' | head -1 | sed 's/.*"\([^"]*\)"$/\1/')
        if [[ -n "$adv_name" ]]; then
            pass "Advertiser info" "Account: $adv_name"
        else
            pass "Advertiser info" "API responding"
        fi
    elif [[ "$response" == *'40105'* ]] || [[ "$response" == *'token'* && "$response" == *'invalid'* ]]; then
        fail "Advertiser info" "Token expired - see CLAUDE.md for refresh steps"
    elif [[ "$response" == *'CURL_FAILED'* ]]; then
        fail "Advertiser info" "Connection failed"
    else
        fail "Advertiser info" "$(echo "$response" | head -c 80)"
    fi
fi
echo

# -----------------------------------------------------------------------------
# Shopify Admin API
# -----------------------------------------------------------------------------
echo "Shopify Admin API"
SHOPIFY_CREDS_FILE="$CONFIG_DIR/shopify-credentials.json"
SHOPIFY_STORE_DOMAIN="shop-cherri.myshopify.com"

# Try to get token from JSON file first, then fall back to env var
if [[ -f "$SHOPIFY_CREDS_FILE" ]]; then
    if command -v jq &> /dev/null; then
        SHOPIFY_ACCESS_TOKEN=$(jq -r '.access_token // empty' "$SHOPIFY_CREDS_FILE" 2>/dev/null)
    else
        # Fallback without jq
        SHOPIFY_ACCESS_TOKEN=$(grep -o '"access_token"[[:space:]]*:[[:space:]]*"[^"]*"' "$SHOPIFY_CREDS_FILE" | cut -d'"' -f4)
    fi
fi

if [[ -z "${SHOPIFY_ACCESS_TOKEN:-}" ]]; then
    skip "API" "Missing access token. Run bin/refresh-shopify-token"
else
    response=$(curl -s -m 15 \
        -H "X-Shopify-Access-Token: ${SHOPIFY_ACCESS_TOKEN}" \
        "https://${SHOPIFY_STORE_DOMAIN}/admin/api/2025-01/shop.json" 2>&1 || echo "CURL_FAILED")

    if [[ "$response" == *'"shop"'* ]]; then
        shop_name=$(echo "$response" | grep -o '"name":"[^"]*"' | head -1 | cut -d'"' -f4)
        pass "Shop info" "Store: $shop_name"
    elif [[ "$response" == *'401'* ]] || [[ "$response" == *'Unauthorized'* ]]; then
        fail "Shop info" "Token expired. Run bin/refresh-shopify-token"
    elif [[ "$response" == *'CURL_FAILED'* ]]; then
        fail "Shop info" "Connection failed"
    else
        fail "Shop info" "$(echo "$response" | head -c 80)"
    fi
fi
echo

# -----------------------------------------------------------------------------
# Gmail
# -----------------------------------------------------------------------------
echo "Gmail"
GMAIL_CREDS_FILE="$HOME/.gmail-mcp/credentials.json"

if [[ ! -f "$GMAIL_CREDS_FILE" ]]; then
    skip "API" "No credentials found. Gmail MCP will prompt for OAuth on first use."
else
    # Extract access token from Gmail MCP credentials
    GMAIL_ACCESS_TOKEN=$(grep -o '"access_token":"[^"]*"' "$GMAIL_CREDS_FILE" | cut -d'"' -f4)

    if [[ -z "$GMAIL_ACCESS_TOKEN" ]]; then
        skip "API" "No access token in credentials file"
    else
        response=$(curl -s -m 15 \
            -H "Authorization: Bearer $GMAIL_ACCESS_TOKEN" \
            "https://gmail.googleapis.com/gmail/v1/users/me/profile" 2>&1 || echo "CURL_FAILED")

        if [[ "$response" == *'"emailAddress"'* ]]; then
            # Handle JSON with or without whitespace
            email=$(echo "$response" | tr -d '\n ' | grep -o '"emailAddress":"[^"]*"' | cut -d'"' -f4)
            pass "Profile" "Account: $email"
        elif [[ "$response" == *'401'* ]] || [[ "$response" == *'UNAUTHENTICATED'* ]]; then
            # Token expired, but refresh token may still work - MCP will auto-refresh
            skip "Profile" "Token expired (MCP will auto-refresh on next use)"
        elif [[ "$response" == *'CURL_FAILED'* ]]; then
            fail "Profile" "Connection failed"
        else
            fail "Profile" "$(echo "$response" | head -c 80)"
        fi
    fi
fi
echo

# -----------------------------------------------------------------------------
# Summary
# -----------------------------------------------------------------------------
echo "----------------------------------------"
echo -e "Results: ${GREEN}${PASSED} passed${NC}, ${RED}${FAILED} failed${NC}, ${YELLOW}${SKIPPED} skipped${NC}"

[[ $FAILED -gt 0 ]] && exit 1
exit 0
