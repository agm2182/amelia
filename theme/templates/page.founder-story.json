    },
    "section_text_XLabFb": {
      "type": "section-text",
      "blocks": {
        "text_KkHLnD": {
          "type": "text",
          "settings": {
            "text": "<p>Gabriella blends body data with bold storytelling, turning Cherri into a brand that’s as inclusive and even somewhat irreverent. She’s passionate about empowering women through humor, design, and unapologetic comfort. <\/p>",
            "size": 100
          }
        },
        "text_DLLG4y": {
          "type": "text",
          "settings": {
            "text": "<p>Gabriella built Cherri to be a reflection of herself: playful, authentic, welcoming, and a little bit unhinged. <\/p>",
            "size": 100
          }
        },
        "text_tjMW34": {
          "type": "text",
          "settings": {
            "text": "<p>She’s not afraid to say “labia” on the internet and neither is her brand.<\/p>",
            "size": 100
          }
        }
      },
      "block_order": [
        "text_KkHLnD",
