    "section_text_E6C7VY": {
      "type": "section-text",
      "blocks": {
        "subheading_xPVJ7c": {
          "type": "subheading",
          "settings": {
            "text": "<p>meet gabriella scaringe<\/p>",
            "size": 100,
            "margin_bottom": 16
          }
        },
        "heading_NyAbfb": {
          "type": "heading",
          "settings": {
            "text": "<p>The Founder Story<\/p>",
            "size": 100,
            "heading_highlight_type": "underline-hand-drawn",
            "highlight_color": "#000000",
            "highlight_text_color": ""
          }
        },
        "image_XMQNxM": {
          "type": "image",
          "settings": {
            "image": "shopify:\/\/shop_images\/000217830037.jpg",
            "image_width": 430,
            "image_link": ""
          }
        },
        "text_EAmNVk": {
          "type": "text",
          "settings": {
            "text": "<p>Gabriella Scaringe is a content creator, data-driven designer, and self-proclaimed coochie connoisseur. <\/p>",
            "size": 100
          }
        },
        "text_BHXi8b": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "<p>So she did what she does best: she overshared on the internet.<\/p>",
            "size": 100
          }
        },
        "text_NLYnNe": {
          "type": "text",
          "disabled": true,
          "settings": {
            "text": "<p>She made jokes about her outie vulva, insecurities she had \"down there\" and went viral multiple times. Thousands of women realized they weren't alone in their insecurities and lip-slips!<\/p>",
            "size": 100
          }
        }
      },
      "block_order": [
        "subheading_xPVJ7c",
        "heading_NyAbfb",
        "image_XMQNxM",
        "text_EAmNVk",
        "text_BHXi8b",
        "text_NLYnNe"
      ],
      "name": "Text",
      "settings": {
