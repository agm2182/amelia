    "cdb3be2a-9d5e-47f0-9431-04f739f3c7cc": {
      "type": "section-image-with-text",
      "settings": {
        "section_height": "three-fifty-height",
        "layout": "overlay",
        "image_location": "left",
        "image_width": "extra-narrow",
        "image": "shopify:\/\/shop_images\/061124_ShopCherri5803.jpg",
        "subheading": "",
        "title": "",
        "heading_highlight_type": "highlight-color",
        "highlight_color": "#d43747",
        "highlight_text_color": "#e90000",
        "heading_size": 130,
        "content": "<ul><li><strong>94%<\/strong> had experienced discomfort, “lip slips,” or even infections from undies that didn’t fit right<\/li><\/ul><p><\/p><ul><li><strong>96%<\/strong> said underwear gussets on the market were just <em>too small<\/em><\/li><\/ul><p><\/p><ul><li>And <strong>78%<\/strong> admitted it actually made them feel insecure about their labia<br\/><\/li><\/ul><p>Let that sink in.<br\/><br\/>Bad underwear wasn’t just uncomfortable—it was messing with people’s self-worth.<\/p>",
        "text_alignment": "left",
        "button_text": "",
        "button_link": "",
        "button_color": "btn--black",
        "button_style": "btn--solid",
        "button_size": "btn--small",
